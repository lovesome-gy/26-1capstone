# ============================================================
# 여주보 수위 예측 AI 시스템 - 환경변수
# cp .env.example .env 후 실제 값으로 채울 것
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=yeoju_water
POSTGRES_USER=yeoju_admin
POSTGRES_PASSWORD=your_strong_password_here

# DATABASE_URL (SQLAlchemy async 형식)
DATABASE_URL=postgresql+asyncpg://yeoju_admin:your_strong_password_here@postgres:5432/yeoju_water

# ── Ollama ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120          # LLM 응답 대기 최대 시간(초)
OLLAMA_MAX_TOKENS=2048

# ── LLM Service (Part④) ────────────────────────────────────
LLM_SERVICE_HOST=0.0.0.0
LLM_SERVICE_PORT=8002
LLM_SERVICE_WORKERS=2

# ── Predictor Service (Part③) ──────────────────────────────
PREDICTOR_BASE_URL=http://predictor:8001

# ── 한강홍수통제소 / K-water ───────────────────────────────
# (실제 API 키는 팀 공유 채널에서 확인)
HRFC_API_KEY=your_hrfc_api_key
KWATER_API_KEY=your_kwater_api_key

# ── 여주보 관측소 ID ────────────────────────────────────────
YEOJU_STATION_ID=3008680     # 여주보 기본 관측소 ID (HRFC 기준)

# ── 로깅 ────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
